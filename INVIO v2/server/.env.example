# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server Configuration
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000

# RapidAPI OTP Configuration (GetOtp.Co WhatsApp)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=getotp-co-send-otps-via-whatsapp-globally-for-free.p.rapidapi.com
RAPIDAPI_PROVIDER_KEY=your-getotp-provider-key
# Set to true only if you want local dev fallback OTP when provider is down.
OTP_ALLOW_FALLBACK=false

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:5173
